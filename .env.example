# =============================================================================
# Resume Matching System — Environment Template
# Copy to .env and fill in secrets. Do not commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Core (Required)
# -----------------------------------------------------------------------------
# OpenAI API key used for embeddings, rerank, and agent evaluation.
# - Keep this secret. Never commit `.env`.
OPENAI_API_KEY=your-openai-api-key
#
# Default LLM used across the system unless overridden by component-specific settings.
OPENAI_MODEL=gpt-4.1-mini
#
# Embedding model for indexing and retrieval.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# Default model for agent evaluation (Skill/Experience/Technical/Culture + negotiation).
OPENAI_AGENT_MODEL=gpt-4.1-mini
#
# If true, enables the "live" agent runtime path when available.
OPENAI_AGENT_LIVE_MODE=true
#
# If true, allows using the Agents SDK handoff path (sdk_runner). If false, fallback paths are used.
OPENAI_AGENTS_SDK_ENABLED=true

# -----------------------------------------------------------------------------
# Database (Required for local run; Docker Compose uses service hostnames)
# -----------------------------------------------------------------------------
# Local: mongodb://admin:admin123@localhost:27017/
# Docker: use DOCKER_MONGODB_URI=mongodb://admin:admin123@mongodb:27017/resume_matching?authSource=admin
# MongoDB connection used as the document source-of-truth for candidate profiles.
MONGODB_URI=mongodb://admin:admin123@localhost:27017/
MONGODB_DB=resume_matching

# Local: http://localhost:19530
# Docker: use DOCKER_MILVUS_URI=http://milvus:19530
# Milvus connection used for vector similarity search.
MILVUS_URI=http://localhost:19530
# Collection name for candidate embedding vectors.
MILVUS_COLLECTION=candidate_embeddings

# -----------------------------------------------------------------------------
# API & Logging
# -----------------------------------------------------------------------------
# Base API prefix used by the FastAPI app.
API_PREFIX=/api
# Log verbosity: DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Token budget & cache (cost control)
# -----------------------------------------------------------------------------
# If enabled, the system may reduce agent usage to stay under an estimated token budget.
TOKEN_BUDGET_ENABLED=false
# Estimated token budget per request (rough guardrail; not exact usage accounting).
TOKEN_BUDGET_PER_REQUEST=20000
# Estimated tokens consumed by one agent call (used for budgeting heuristics).
TOKEN_ESTIMATED_PER_AGENT_CALL=800

# Cache match_jobs result by JD hash + params (in-memory LRU)
# In-memory response cache for `match_jobs`. Great for repeated identical JDs during demos/tests.
TOKEN_CACHE_ENABLED=true
TOKEN_CACHE_TTL_SEC=300
TOKEN_CACHE_MAX_SIZE=128

# -----------------------------------------------------------------------------
# Ingestion API guardrails
# -----------------------------------------------------------------------------
# Optional API key for ingestion endpoints (leave empty to disable key enforcement).
INGESTION_API_KEY=
# Basic rate-limit guardrail for ingestion endpoints.
INGESTION_RATE_LIMIT_PER_MINUTE=3
# If true, ingestion can run asynchronously (server returns quickly and completes in background).
INGESTION_ALLOW_ASYNC=true

# -----------------------------------------------------------------------------
# Query fallback (low-confidence query handling)
# -----------------------------------------------------------------------------
# If enabled, low-confidence deterministic JD parsing can fall back to an LLM-backed query profile.
QUERY_FALLBACK_ENABLED=true
QUERY_FALLBACK_MODEL=gpt-4.1-mini
# Trigger fallback when deterministic confidence is below this threshold.
QUERY_FALLBACK_CONFIDENCE_THRESHOLD=0.62
# Trigger fallback when the unknown-signal ratio exceeds this threshold.
QUERY_FALLBACK_UNKNOWN_RATIO_THRESHOLD=0.55

# -----------------------------------------------------------------------------
# Rerank
# -----------------------------------------------------------------------------
# If true, rerank can be invoked (still subject to gate conditions).
RERANK_ENABLED=false
# Rerank mode: `llm` or `embedding` depending on implementation/routing.
RERANK_MODE=llm
# Primary rerank model (used when mode=llm and routing selects this model).
RERANK_MODEL=gpt-4.1-mini
RERANK_MODEL_DEFAULT=gpt-4.1-mini
RERANK_MODEL_DEFAULT_VERSION=baseline-v1
RERANK_MODEL_HIGH_QUALITY=gpt-4.1-mini
RERANK_MODEL_HIGH_QUALITY_VERSION=hq-v1
# Embedding model used when rerank_mode=embedding (or for embedding-based rerank paths).
RERANK_EMBEDDING_MODEL=text-embedding-3-small
# Candidate pool size considered for rerank.
RERANK_TOP_N=20
# Hard timeout for rerank stage.
RERANK_TIMEOUT_SEC=12.0
RERANK_GATE_MAX_TOP_N=8
RERANK_GATE_TOP2_GAP_THRESHOLD=0.04
RERANK_GATE_CONFIDENCE_THRESHOLD=0.65
RERANK_GATE_UNKNOWN_RATIO_THRESHOLD=0.5
# Number of candidates to send through the agent evaluation pipeline (top-N by deterministic score).
AGENT_EVAL_TOP_N=4
# LLM-as-Judge model used in eval scripts.
EVAL_JUDGE_MODEL=gpt-4o
EVAL_JUDGE_MODEL_VERSION=judge-v1

# -----------------------------------------------------------------------------
# Fairness guardrails
# -----------------------------------------------------------------------------
# If true, compute fairness warnings and include them in responses.
FAIRNESS_GUARDRAILS_ENABLED=true
FAIRNESS_POLICY_VERSION=v1
FAIRNESS_SENSITIVE_TERM_ENABLED=true
FAIRNESS_MAX_CULTURE_WEIGHT=0.2
FAIRNESS_MIN_MUST_HAVE_MATCH_RATE=0.5
FAIRNESS_HIGH_CULTURE_CONFIDENCE=0.7
FAIRNESS_RANK_SCORE_FLOOR=0.7
FAIRNESS_TOPK_DISTRIBUTION_MIN=5
FAIRNESS_SENIORITY_CONCENTRATION_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# Ranking blend & fallback weight negotiation
# -----------------------------------------------------------------------------
# rank_score = (RANK_DETERMINISTIC_WEIGHT * deterministic_score) + (RANK_AGENT_WEIGHT * agent_weighted_score)
RANK_DETERMINISTIC_WEIGHT=0.30
RANK_AGENT_WEIGHT=0.70

# JSON dicts (Pydantic will parse JSON from env)
# Fallback weights used when LLM negotiation is unavailable.
FALLBACK_RECRUITER_WEIGHTS={"skill":0.30,"experience":0.35,"technical":0.20,"culture":0.15}
FALLBACK_HIRING_MANAGER_WEIGHTS={"skill":0.40,"experience":0.20,"technical":0.30,"culture":0.10}

FALLBACK_RECRUITER_EXPERIENCE_YEARS_THRESHOLD=5.0
FALLBACK_RECRUITER_EXPERIENCE_BOOST=0.10
FALLBACK_RECRUITER_TECHNICAL_REDUCTION=0.05
FALLBACK_RECRUITER_CULTURE_REDUCTION=0.05

FALLBACK_HM_REQUIRED_SKILLS_THRESHOLD=6
FALLBACK_HM_TECHNICAL_BOOST=0.10
FALLBACK_HM_EXPERIENCE_REDUCTION=0.05
FALLBACK_HM_CULTURE_REDUCTION=0.05

# -----------------------------------------------------------------------------
# Optional — Observability (LangSmith)
# -----------------------------------------------------------------------------
# If true, enable LangSmith tracing (requires API key).
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=resume-matching

# -----------------------------------------------------------------------------
# Optional — Confident AI (if used; not loaded by backend/core/settings.py)
# -----------------------------------------------------------------------------
# CONFIDENT_API_KEY=your-confident-api-key
# CONFIDENT_REGION=US
